.panel {
    background-color: rgba(30, 130, 81, 0.58);
}

.title {
    font-size: 80px;
    align-items: auto;
    align-self: auto;
}

.menu {
    width: 50%;
    max-height: 80%;
    align-self: center;
    align-items: center;
    background-color: rgb(0, 7, 123);
    transition-duration: 0s;
    transition-property: all;
}

.button {
    font-size: 110px;
    -unity-text-align: middle-center;
    align-self: stretch;
    align-items: stretch;
    align-content: stretch;
    justify-content: flex-start;
    flex-grow: 1;
    border-top-left-radius: 80px;
    border-top-right-radius: 80px;
    border-bottom-right-radius: 80px;
    border-bottom-left-radius: 80px;
    border-left-color: rgb(131, 184, 24);
    border-right-color: rgb(131, 184, 24);
    border-top-color: rgb(131, 184, 24);
    border-bottom-color: rgb(131, 184, 24);
    border-top-width: 10px;
    border-right-width: 10px;
    border-bottom-width: 10px;
    border-left-width: 10px;
    background-color: rgb(255, 255, 255);
    -unity-font-style: bold;
    margin-top: 10px;
    margin-bottom: 10px;
}

.button_level {
    font-size: 60px;
    -unity-text-align: middle-center;
    align-self: stretch;
    align-items: stretch;
    align-content: stretch;
    justify-content: flex-start;
    flex-grow: 1;
    border-radius: 80px;
    border-color: rgb(131, 184, 24);
    border-width: 10px;
    background-color: rgb(255, 255, 255);
    -unity-font-style: bold;
    margin-top: 10px;
    margin-bottom: 10px;
}

.button:active {
    background-color: rgb(131, 184, 24); /* Gr�n */
}

.slider {
    align-self: stretch;
    font-size: 100px;
    height: auto;
}

#SliderSensitivity .unity-base-slider__dragger {
    background-color: rgb(131, 184, 24);
    width: 100px;
    height: 100px;
    border-radius: 25px;
    position: absolute;
    top: 25%;
}

#SliderSensitivity .unity-base-slider__tracker {
    background-color: rgb(204, 204, 204);
    height: 20px;
    position: relative;
}

#LevelList .unity-base-slider__dragger {
    background-color: rgb(131, 184, 24);
    border-radius: 17px;
    width: 35px;
    align-self: center;
}

#LevelList .unity-base-slider__tracker {
    background-color: rgb(204, 204, 204);
    width: 40px;
    border-width: 0;
    border-radius: 17px;
}

#LevelList .unity-base-slider {
    background-color: rgb(204, 204, 204);
    width: 40px;
}

#LevelList .unity-scroller__high-button,
#LevelList .unity-scroller__low-button {
    display: none !important; /* Unsichtbar machen */
}

#LevelList .unity-scroller--vertical > .unity-scroller__slider {
    margin: 0;
    margin-left: 20px;
    border-radius: 17px;
    border-width: 0;
}

#OptionsMenu .unity-toggle__input {
    width: 80px;
    height: 80px;
    min-width: 80px;
    min-height: 80px;
    background-color: rgb(255, 255, 255);
    border-radius: 20px;
    border-width: 5px;
    border-color: rgb(131, 184, 24);
    flex-grow: 0;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    background-image: none; /* Removes default background sprite */
}

#OptionsMenu .unity-toggle__checkmark {
    width: 80px;
    height: 80px;
    -unity-background-image-tint-color: rgb(131, 184, 24);
}

#OptionsMenu .unity-toggle {
    margin-bottom: 20px;
    align-items: center; /* Aligns label and checkbox vertically centered */
    justify-content: space-between; /* Pushes label to left, checkbox to right */
}

#OptionsMenu .unity-toggle__label {
    flex-grow: 1; /* Allows label to take up space */
    font-size: 100px; /* Matches other title/text sizes */
    margin-right: 20px;
}
